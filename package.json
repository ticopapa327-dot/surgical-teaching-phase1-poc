    "start": "electron ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^10.0.3",
    "electron": "^39.2.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "wait-on": "^9.0.3"
  }
}
