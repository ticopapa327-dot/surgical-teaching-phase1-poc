{
  "name": "surgical-teaching-phase1-poc",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 PoC for Windows C/S surgical teaching software: 4-channel USB preview, selective recording, audio capture and local playback index.",
  "main": "electron/main.cjs",
  "scripts": {
